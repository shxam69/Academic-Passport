# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- PostgreSQL (consumed starting Module 3) ---
POSTGRES_DB=academic_passport
POSTGRES_USER=academic_passport_app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_PORT=5432

# --- App ---
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# --- JWT (consumed starting Module 5) ---
# Generate a real 256-bit+ secret locally, e.g.: openssl rand -base64 48
JWT_SECRET=change_me_locally

# --- ClamAV ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
